{
  "name": "@dcyfr/ai-cli",
  "version": "1.0.3",
  "description": "DCYFR AI Command-Line Interface - Portable CLI tool for DCYFR AI harness",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dcyfr": "./bin/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && tsc --incremental false && tsc-alias",
    "build:watch": "tsc --watch",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "cli": "tsx src/cli.ts",
    "prepublishOnly": "npm run clean && npm run build && npm run test",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "example:status": "tsx src/cli.ts status",
    "example:init": "tsx src/cli.ts init",
    "example:validate": "tsx src/cli.ts validate",
    "example:telemetry": "tsx src/cli.ts telemetry",
    "examples:compile": "npm run typecheck",
    "examples:check": "npm run example:status && npm run example:init && npm run example:telemetry",
    "examples:test": "npm run examples:compile && npm run examples:check",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release": "npm run build && changeset publish",
    "version:patch": "npm version patch -m 'chore: bump version to %s'",
    "version:minor": "npm version minor -m 'chore: bump version to %s'",
    "version:major": "npm version major -m 'chore: bump version to %s'",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "dcyfr",
    "ai",
    "cli",
    "command-line",
    "typescript",
    "nodejs"
  ],
  "author": "DCYFR",
  "license": "MIT",
  "dependencies": {
    "chokidar": "^5.0.0",
    "commander": "^14.0.2"
  },
  "peerDependencies": {
    "@dcyfr/ai": "^3.0.1"
  },
  "peerDependenciesMeta": {
    "@dcyfr/ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "prettier": "^3.4.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "axios": "^1.8.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dcyfr/dcyfr-ai-cli"
  },
  "homepage": "https://github.com/dcyfr/dcyfr-ai-cli#readme",
  "bugs": {
    "url": "https://github.com/dcyfr/dcyfr-ai-cli/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
